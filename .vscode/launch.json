{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch SecurityRules API",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "DB_PASSWORD": "1010data",
                "DB_NAME": "DATA_QUALITY",
                "DB_HOST": "localhost",
                "DB_PORT": "5432",
                "DB_USER": "postgres",
                "PORT": "3000"
            },
            "args": []
        },
        {
            "name": "Launch SecurityRules API (Snowflake)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "SNOWFLAKE_ACCOUNT": "<your_account>",
                "SNOWFLAKE_USER": "<your_username>",
                "SNOWFLAKE_PASSWORD": "<your_password>",
                "SNOWFLAKE_DATABASE": "DATA_QUALITY",
                "SNOWFLAKE_WAREHOUSE": "<your_warehouse>",
                "SNOWFLAKE_ROLE": "<your_role>",
                "SNOWFLAKE_SCHEMA": "PUBLIC",
                "PORT": "3000"
            },
            "args": []
        },
        {
            "name": "Launch SecurityRules API (SQL Server)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "SQLSERVER_HOST": "<your_server>",
                "SQLSERVER_PORT": "1433",
                "SQLSERVER_USER": "<your_username>",
                "SQLSERVER_PASSWORD": "<your_password>",
                "SQLSERVER_DATABASE": "DATA_QUALITY",
                "PORT": "3000"
            },
            "args": []
        },
        {
            "name": "Attach to Process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": 0
        }
    ]
}
